% Новые поля
\def\studentInitials#1{\gdef\@studentInitials{#1}}
\def\@studentInitials{\@latex@warning@no@line{No \noexpand\studentInitials given}}

\def\supervisorInitials#1{\gdef\@supervisorInitials{#1}}
\def\@supervisorInitials{\@latex@warning@no@line{No \noexpand\supervisorInitials given}}

\def\supervisorDegree#1{\gdef\@supervisorDegree{#1}}
\def\@supervisorDegree{\@latex@warning@no@line{No \noexpand\supervisorDegree given}}

\def\headOfDepartmentInitials#1{\gdef\@headOfDepartmentInitials{#1}}
\def\@headOfDepartmentInitials{\@latex@warning@no@line{No \noexpand\headOfDepartmentInitials given}}

\def\percentageOfBorrowings#1{\gdef\@percentageOfBorrowings{#1}}
\def\@percentageOfBorrowings{\@latex@warning@no@line{No \noexpand\percentageOfBorrowings given}}

\def\firstConsultantInitials#1{\gdef\@firstConsultantInitials{#1}}
\def\firstConsultantDegree#1{\gdef\@firstConsultantDegree{#1}}
\def\secondConsultantInitials#1{\gdef\@secondConsultantInitials{#1}}
\def\secondConsultantDegree#1{\gdef\@secondConsultantDegree{#1}}
