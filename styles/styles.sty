  \endgroup
}

\newcommand\makeAffiliation{
  \begingroup
  \fontsize{12pt}{16pt}\selectfont
  \textbf{Институт (Филиал)} \uline{\@faculty\hfill} \textbf{Кафедра} \uline{\@department\hfill} \\
  \textbf{Группа} \uline{\@group} \textbf{Направление подготовки} \expandafter\uline\expandafter{\expanded{\@speciality}\hfill} \\
  \textbf{Профиль} \uline{\@profile\hfill} \\
  \textbf{Квалификация:} \uline{\textbf{бакалавр}\hfill}
  \endgroup
}

\newcommand\makeThemeLine{
  \textbf{Наименование темы} \expandafter\uline\expandafter{\expanded{\@theme}\hfill}
}

\newcommand\makeSupervisorLine[2]{
  \textbf{#1} \uline{\csname @#2\endcsname,\hfill}\\
  \uline{\csname @#2Degree\endcsname\hfill}
}

\newcommand\makeStudentLine{
  \textbf{Обучающийся} \uline{\@student\hfill}
}

\newcommand\makeTitle[1]{
  \begin{center}
    \bfseries\fontsize{18pt}{20pt}\selectfont 
    #1
  \end{center}
}

% Задание на ВКР
\newcommand\makeHeadOfDepartmentSignature{
  \bigskip
  \hfill
  \begin{minipage}[t]{\widthof{Заведующий кафедрой \@department\ \uline{\hspace{1.5cm}}\ \@headOfDepartmentInitials}}
    \centering
    \textbf{УТВЕРЖДАЮ}\\
    \raggedleft
    Заведующий кафедрой \@department\ \uline{\hspace{1.5cm}}\ \@headOfDepartmentInitials\\
    \uline{\hspace{1cm}}\ \uline{\hspace{2cm}}\ \the\year{г.}
  \end{minipage}
}

\newcommand\makeTaskSignatures{
  \hfill
  \begin{minipage}[t]{0.7\textwidth}
    \setlength{\parskip}{.5\baselineskip plus 2pt}
    Руководитель\ \uline{\hfill\@supervisorInitials}

    Задание принял к исполнению\ \uline{\hfill\@studentInitials}
  \end{minipage}
}

% Отзывы
\newcommand\makeBorrowingsLine{
  Работа проверена на объем заимствования. \% заимствования -- \@percentageOfBorrowings\%
}

\newcommand\makeReviewResult[1]{
  Заключение:
  \uline{Выпускная квалификационная работа бакалавра заслуживает оценки <<#1>>, а ее автор -- \@studentInitials
  \ -- присвоения квалификации бакалавра по направлению \@speciality.\hfill}
}

\newcommand\makeReviewSignature[2]{
  \uline{\hspace{1cm}}\ \uline{\hspace{2.5cm}}\ \the\year{г.}\hfill
  #1\ \uline{\hspace{2cm}\csname @#2Initials\endcsname}
}

\newcommand\makeConsultantReview[3]{
  \makeInstituteHeader
  
  \makeTitle{О Т З Ы В\\\fontsize{14pt}{16pt}\selectfont КОНСУЛЬТАНТА}

  \begingroup
  \makeStudentLine

  \setlength{\parskip}{.5\baselineskip plus 2pt}
  
  \makeAffiliation

  \makeThemeLine

  \makeSupervisorLine{Консультант}{#1}

  \uline{\hspace{1.25cm}
  #2
  \hfill}

  \makeReviewResult{#3}

  \makeReviewSignature{Консультант}{#1}
  \endgroup

  \vfill
  \clearpage
}

